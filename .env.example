# ==========================================
# API KEYS (REQUIRED)
# ==========================================
# OpenLLMetry (Traceloop) API Key (Free at https://app.traceloop.com)
TRACELOOP_API_KEY=your_traceloop_api_key_here

# Firecrawl API Key for web scraping (Free at https://firecrawl.dev)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Gemini API for rag json formatting
GEMINI_API_KEY=your_gemini_api_key

# OpenAI fake API key for package compliance
OPENAI_API_KEY = "fake-key-per-evitare-errore"

# ==========================================
# MODELS CONFIGURATION
# ==========================================
# Modello per l'Estrazione (Ingestion) in Cloud
INGEST_LLM_MODEL=gemini-1.5-flash
# Modello per l'Interrogazione (Chat) in Locale
CHAT_LLM_MODEL=llama3.2:1b
# Context size set to 64KB (8192 tokens)
LLM_CONTEXT_WINDOW=8192
# Embedding: BGE-M3
EMBEDDING_MODEL=bge-m3

# ==========================================
# LIGHTRAG WORKSPACE
# ==========================================
# Persistent storage directory for Knowledge Graph and Vector DB
LIGHTRAG_WORKSPACE=/app/kb
